{
  "name": "kronk-bot",
  "version": "1.0.0",
  "description": "Self-driving git bot that turns open issues into merged code",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --import tsx/esm --test src/**/*.test.ts"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.59.0",
    "better-sqlite3": "^11.0.0",
    "octokit": "^5.0.5",
    "pino": "^10.3.1",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
