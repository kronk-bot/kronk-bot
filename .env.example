# Required — GitHub App credentials
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Required — LLM provider
OPENROUTER_API_KEY=sk-or-your_key_here

# Optional — model
MODEL=minimax/minimax-m2.5

# Optional — trigger and storage
TRIGGER_WORD=@kronk-bot    # the mention word that triggers the bot
DB_PATH=/data/db.sqlite     # SQLite database path

# Optional — polling
POLL_INTERVAL=60            # seconds between polls
PROCESSING_TIMEOUT=900      # seconds before a stuck "Processing..." comment is retried

# Optional — paths
WORK_DIR=/data/workspace    # repos are cloned to {WORK_DIR}/{owner}/{repo}
